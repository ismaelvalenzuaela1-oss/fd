{
  "multipart": [
    {
      "when": { "up": true },
      "apply": [
        { "model": "minecraft:block/mossy_stone_brick_wall_post", "y": 0 },
        { "model": "minecraft:block/mossy_stone_brick_wall_post", "y": 90 },
        { "model": "minecraft:block/mossy_stone_brick_wall_post", "y": 180 },
        { "model": "minecraft:block/mossy_stone_brick_wall_post", "y": 270 }
      ]
    },

    { "when": { "north": "low"  }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side",      "y": 0   } },
    { "when": { "east":  "low"  }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side",      "y": 90  } },
    { "when": { "south": "low"  }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side",      "y": 180 } },
    { "when": { "west":  "low"  }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side",      "y": 270 } },

    { "when": { "north": "tall" }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side_tall", "y": 0   } },
    { "when": { "east":  "tall" }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side_tall", "y": 90  } },
    { "when": { "south": "tall" }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side_tall", "y": 180 } },
    { "when": { "west":  "tall" }, "apply": { "model": "minecraft:block/mossy_stone_brick_wall_side_tall", "y": 270 } }
  ]
}